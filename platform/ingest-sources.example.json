{
  "engine": "http://127.0.0.1:8080",
  "ingestExecutable": "../cpp-engine/build/ffmpeg_stream_ingest.exe",
  "ffmpeg": "ffmpeg",
  "apiKeyEnv": "PAMGUARD_API_KEY",
  "statusFile": "../data/ingest-supervisor-status.json",
  "statusIntervalSeconds": 5,
  "workerRestartDelaySeconds": 5,
  "maxWorkerRestarts": 0,
  "defaults": {
    "sampleRateHz": 48000,
    "channels": 2,
    "chunkFrames": 4096,
    "restart": true,
    "restartDelayMs": 5000,
    "allowExistingSession": true,
    "resumeFromEngine": true,
    "realtime": true
  },
  "sources": [
    {
      "enabled": false,
      "id": "station-001",
      "session": "station-001",
      "ownerId": "demo-user",
      "tenantId": "demo-project",
      "source": "http://station.example/live.mp3",
      "sessionConfig": "station-session.example.json"
    },
    {
      "enabled": false,
      "id": "harbour-array",
      "session": "harbour-array",
      "ownerId": "demo-user",
      "tenantId": "demo-project",
      "source": "http://icecast.example/hydrophones.wav",
      "sessionConfig": "array-session.example.json",
      "channels": 4,
      "ffmpegInputOptions": ["-fflags", "nobuffer"],
      "audioFilter": "pan=4c|c0=c0|c1=c1|c2=c2|c3=c3"
    }
  ]
}
